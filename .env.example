# StellaCode Configuration
# Copy this file to .env and adjust values as needed.

# Server port (default: 3001)
STELLA_PORT=3001

# Target project to scan (default: current directory)
STELLA_TARGET=.

# Additional CORS origins, comma-separated (default: localhost only)
# Example: STELLA_CORS_ORIGINS=https://my-server.com,https://team.internal:8080
STELLA_CORS_ORIGINS=
